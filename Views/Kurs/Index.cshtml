@model IEnumerable<Kurs>
@{
    ViewData["Title"] = "Index";
}

<h2>Kurs Listesi</h2>
<hr />
<table class="table table-bordered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(i => i.KursId)</th> @* DisplayNameFor, belirtilen model özelliğinin kullanıcı dostu bir adını görüntülemek için kullanılır. Bu durumda, i.OgrenciId'nin kullanıcı dostu adını görüntüler. Genellikle, model sınıfındaki özelliklerin adlarını daha okunabilir hale getirmek için kullanılır. *@
            <th>@Html.DisplayNameFor(i => i.Baslik)</th>
            <th>@Html.DisplayNameFor(i => i.Ogretmen.AdSoyadOgretmen)</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td style="width: 150px;">@Html.DisplayFor(modelItem => item.KursId)</td> @* DisplayFor, belirtilen model özelliğinin değerini görüntülemek için kullanılır. Bu durumda, item.OgrenciId'nin değerini görüntüler. *@
                <td>@Html.DisplayFor(modelItem => item.Baslik)</td>
                <td>@Html.DisplayFor(modelItem => item.Ogretmen.AdSoyadOgretmen)</td>
                <td style="width: 150px;">
                    <a asp-controller="Kurs" asp-action="Edit" asp-route-id="@item.KursId" class="btn btn-sm btn-primary">Düzenle</a>
                    <a asp-controller="Kurs" asp-action="Delete" asp-route-id="@item.KursId" class="btn btn-sm btn-danger">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a class="btn btn-success mb-3" asp-controller="Kurs" asp-action="Create">Yeni Kurs Ekle</a>
